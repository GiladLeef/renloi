#include <std.h>
#include <thread.h>

void taskFunction(int id) {
    print("Task ", id, " is running on thread ",  thread.get_id());
}

int main() {
    const size_t num_threads = 4;
    ThreadPool threadPool(num_threads);

    // Add tasks to the thread pool
    for (int i = 0; i < 8; ++i) {
        threadPool.addTask(taskFunction, i);
    }

    threadPool.stop();
    threadPool.wait();

    return 0;
}
