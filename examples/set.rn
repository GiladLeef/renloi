#include <std.h>
#include <set.h>

int main() {
    // Example usage with int
    Set<int> intSet;
    intSet.add(3);
    intSet.add(1);
    intSet.add(4);
    intSet.print();  // Output: 1 3 4

    // Example usage with double
    Set<double> doubleSet;
    doubleSet.add(2.5);
    doubleSet.add(1.1);
    doubleSet.add(4.8);
    doubleSet.print();  // Output: 1.1 2.5 4.8

    return 0;
}
