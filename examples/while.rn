#include <stdio>

int main() {
    // Initialize a counter
    int counter = 1;

    // Define the while loop
    while (counter <= 5) {
        // Print the current value of the counter
        print("Counter: " + counter);

        // Increment the counter
        counter++;
    }

    // Print a message after the loop is done
    print("Loop finished!");

    return 0;
}
